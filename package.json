{
  "name": "ai-lab",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "pnpm -r --sort build",
    "check": "pnpm format && pnpm lint && pnpm typecheck && pnpm code:shape && pnpm coverage && pnpm build && pnpm docs:check",
    "cli": "node apps/cli/dist/index.js",
    "code:shape": "node tools/check-code-shape.mjs",
    "docs:check": "node tools/check-docs.mjs",
    "format": "biome check .",
    "format:write": "biome check --write .",
    "lint": "eslint . && depcruise apps packages --config .dependency-cruiser.cjs",
    "service:dev": "tsx apps/service/src/index.ts",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "typecheck": "tsc -b"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.10.7",
    "@vitest/coverage-v8": "^2.1.9",
    "dependency-cruiser": "^16.10.4",
    "eslint": "^9.18.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vitest": "^2.1.8"
  }
}
